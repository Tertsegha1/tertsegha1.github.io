{
  "rules": {
    "pyacademy": {
      "passcodes": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$code": {
          ".read": true,
          "usedCount": { ".write": true },
          "usedBy": { ".write": true },
          "active": { ".write": "auth != null || newData.val() === false" }
        }
      },
      "messages": {
        ".read": "auth != null",
        ".write": true,
        "$key": {
          ".read": true
        }
      },
      "feedback": {
        ".read": "auth != null",
        ".write": true
      },
      "users": {
        ".read": "auth != null",
        "$username": {
          ".read": true,
          ".write": "data.exists() || auth != null || (newData.child('passcodeUsed').exists() && root.child('pyacademy').child('passcodes').child(newData.child('passcodeUsed').val()).child('active').val() === true)"
        }
      },
      "certificates": {
        ".read": "auth != null",
        "$certId": {
          ".read": true,
          ".write": "!data.exists() && newData.child('username').val() != null && root.child('pyacademy').child('users').child(newData.child('username').val()).exists()"
        }
